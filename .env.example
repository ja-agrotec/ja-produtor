# =================================================================
# JA Agrotec - Modulo Produtor - variaveis de ambiente
# Copie para .env.local e preencha com os valores REAIS do seu projeto.
# NUNCA versione .env.local nem cole valores reais aqui.
# =================================================================

# Supabase (Project Settings > API > Publishable and secret)
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx
# service_role - NUNCA exponha no frontend (so usar em /app/api/*)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxx

# Anthropic (opcional) - habilita /api/ia-operacional com diagnostico Claude Haiku.
# Sem essa chave, a tela /ia-operacional cai automaticamente pro modo heuristico local.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxx
